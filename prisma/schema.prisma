generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Admin {
  id       String  @id @default(cuid())
  email    String  @unique
  password String
  name     String?
}

model Category {
  id             String    @id @default(cuid())
  name           String
  name_fr        String?
  description    String?
  description_fr String?
  image          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  description_pt String?
  name_pt        String?
  description_ar String?
  name_ar        String?
  products       Product[]
}

model Product {
  id             String   @id @default(cuid())
  name           String
  name_fr        String?
  description    String?
  description_fr String?
  image          String?
  categoryId     String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  isAvailable    Boolean  @default(true)
  order          Int      @default(0)
  description_pt String?
  name_pt        String?
  description_ar String?
  name_ar        String?
  category       Category @relation(fields: [categoryId], references: [id])
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model ContactMessage {
  id         String   @id @default(cuid())
  name       String
  email      String
  phone      String?
  company    String?
  subject    String?
  message    String
  productUrl String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Visit {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userAgent String?
  ip        String?
  path      String?
  country   String?
}

model visits_numidex {
  id        String   @id
  date      DateTime @default(now())
  userAgent String?
  ipAddress String?
  path      String?
  country   String?
}

model madeinbladi_site_visits {
  id        String   @id
  date      DateTime @default(now())
  userAgent String?
  ipAddress String?
  path      String?
  country   String?
}
